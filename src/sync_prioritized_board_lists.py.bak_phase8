
from __future__ import annotations

import argparse
import sqlite3
from pathlib import Path
from typing import Iterable


GREENHOUSE_FILE = "greenhouse_boards.txt"
LEVER_FILE = "lever_boards.txt"


def connect(db_path: str) -> sqlite3.Connection:
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row
    return conn


def normalize_root(url: str) -> str:
    return (url or "").strip()


def read_existing_lines(path: Path) -> list[str]:
    if not path.exists():
        return []
    return [line.strip() for line in path.read_text().splitlines() if line.strip()]


def query_prioritized_roots(conn: sqlite3.Connection, ats_type: str) -> list[str]:
    # Prefer board/root identity, not hostname aggregates
    rows = conn.execute(
        """
        SELECT
            source_root,
            COALESCE(priority_score, 0) AS priority_score,
            matching_job_count,
            seen_count,
            source_key
        FROM source_registry
        WHERE ats_type = ?
          AND COALESCE(source_root, '') <> ''
          AND status = 'active'
        ORDER BY COALESCE(priority_score, 0) DESC,
                 matching_job_count DESC,
                 seen_count DESC,
                 source_key
        """,
        (ats_type,),
    ).fetchall()

    ordered = []
    seen = set()
    for row in rows:
        root = normalize_root(row["source_root"])
        if not root or root in seen:
            continue
        ordered.append(root)
        seen.add(root)
    return ordered


def merge_with_existing(prioritized: list[str], existing: list[str]) -> list[str]:
    ordered = []
    seen = set()
    for value in prioritized + existing:
        value = normalize_root(value)
        if not value or value in seen:
            continue
        ordered.append(value)
        seen.add(value)
    return ordered


def write_lines(path: Path, values: Iterable[str]) -> None:
    path.write_text("\n".join(values) + "\n")


def main() -> None:
    parser = argparse.ArgumentParser(description="Rewrite ATS board lists ordered by source priority")
    parser.add_argument("--db", required=True, help="Path to SQLite DB")
    parser.add_argument("--repo-root", default=".", help="Repo root containing board txt files")
    parser.add_argument("--dry-run", action="store_true", help="Print results only")
    args = parser.parse_args()

    repo_root = Path(args.repo_root).resolve()
    greenhouse_path = repo_root / GREENHOUSE_FILE
    lever_path = repo_root / LEVER_FILE

    conn = connect(args.db)

    prioritized_greenhouse = query_prioritized_roots(conn, "Greenhouse")
    prioritized_lever = query_prioritized_roots(conn, "Lever")

    merged_greenhouse = merge_with_existing(prioritized_greenhouse, read_existing_lines(greenhouse_path))
    merged_lever = merge_with_existing(prioritized_lever, read_existing_lines(lever_path))

    print("\n=== GREENHOUSE BOARDS (top 20) ===")
    for line in merged_greenhouse[:20]:
        print(line)

    print("\n=== LEVER BOARDS (top 20) ===")
    for line in merged_lever[:20]:
        print(line)

    if args.dry_run:
        print("\nDry run only. No files written.")
    else:
        write_lines(greenhouse_path, merged_greenhouse)
        write_lines(lever_path, merged_lever)
        print(f"\nWrote {len(merged_greenhouse)} Greenhouse boards to {greenhouse_path}")
        print(f"Wrote {len(merged_lever)} Lever boards to {lever_path}")

    conn.close()


if __name__ == "__main__":
    main()
